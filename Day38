#include <stdio.h>

#define MAX 100

int deque[MAX];
int front = -1, rear = -1;

void push_front(int x)
{
    if(front == -1)
    {
        front = rear = 0;
        deque[front] = x;
    }
    else
    {
        front--;
        deque[front] = x;
    }
}

void push_back(int x)
{
    if(front == -1)
    {
        front = rear = 0;
    }
    else
    {
        rear++;
    }
    deque[rear] = x;
}

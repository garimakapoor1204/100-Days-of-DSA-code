#include <stdio.h>

int main() {
    int i, j;

    // zeros() -> initialize with 0
    int zeros[2][3] = {0};
    printf("Zeros Array:\n");
    for(i=0;i<2;i++){
        for(j=0;j<3;j++){
            printf("%d ", zeros[i][j]);
        }
        printf("\n");
    }

    // ones() -> manually assign 1
    int ones[2][2];
    for(i=0;i<2;i++){
        for(j=0;j<2;j++){
            ones[i][j] = 1;
        }
    }

    printf("\nOnes Array:\n");
    for(i=0;i<2;i++){
        for(j=0;j<2;j++){
            printf("%d ", ones[i][j]);
        }
        printf("\n");
    }

    // arange()
    printf("\nArange (1 to 9 step 2):\n");
    for(i=1;i<10;i+=2){
        printf("%d ", i);
    }

    // linspace() approximation
    printf("\n\nLinspace (0 to 1, 5 points):\n");
    float start = 0, end = 1;
    int n = 5;
    float step = (end - start)/(n-1);

    for(i=0;i<n;i++){
        printf("%.2f ", start + i*step);
    }

    return 0;
}

int parent[100005];

int find(int x) {
    if (parent[x] != x)
        parent[x] = find(parent[x]);
    return parent[x];
}

int isCycle(int** edges, int E, int V) {
    for (int i = 0; i < V; i++)
        parent[i] = i;

    for (int i = 0; i < E; i++) {
        int* e = edges[i];
        int u = e[0];
        int v = e[1];

        int pu = find(u);
        int pv = find(v);

        if (pu == pv)
            return 1;

        parent[pu] = pv;
    }

    return 0;
}

#include <stdio.h>
#include <stdlib.h>
#include <ctype.h>

struct node
{
    int data;
    struct node *next;
};

struct node *top = NULL;

void push(int x)
{
    struct node *temp = (struct node*)malloc(sizeof(struct node));
    temp->data = x;
    temp->next = top;
    top = temp;
}

int pop()
{
    struct node *temp = top;
    int val = temp->data;
    top = temp->next;
    free(temp);
    return val;
}

int main()
{
    char exp[100];
    int i = 0;

    printf("Enter postfix expression: ");
    fgets(exp,100,stdin);

    while(exp[i] != '\0')
    {
        if(isdigit(exp[i]))
        {
            push(exp[i] - '0');
        }

        else if(exp[i]=='+' || exp[i]=='-' || exp[i]=='*' || exp[i]=='/')
        {
            int b = pop();
            int a = pop();
            int result;

            if(exp[i]=='+')
                result = a + b;
            else if(exp[i]=='-')
                result = a - b;
            else if(exp[i]=='*')
                result = a * b;
            else
                result = a / b;

            push(result);
        }

        i++;
    }

    printf("Result = %d\n", pop());

    return 0;
}

#include <stdio.h>
#include <string.h>

int main() {
    char str[1000];
    int freq[26] = {0};   // for lowercase letters

    // Input
    scanf("%s", str);

    // Count frequency
    for (int i = 0; str[i] != '\0'; i++) {
        freq[str[i] - 'a']++;
    }

    // Find first non-repeating character
    for (int i = 0; str[i] != '\0'; i++) {
        if (freq[str[i] - 'a'] == 1) {
            printf("%c", str[i]);
            return 0;
        }
    }

    // If none found
    printf("$");

    return 0;
}

#include <stdio.h>
#include <stdlib.h>

struct Node {
    int val;
    struct Node* left;
    struct Node* right;
};

struct Node* createNode(int val) {
    struct Node* node = (struct Node*)malloc(sizeof(struct Node));
    node->val = val;
    node->left = node->right = NULL;
    return node;
}

struct Node* build(int inorder[], int postorder[], int *postIndex,
                   int inStart, int inEnd, int map[]) {
    
    if (inStart > inEnd)
        return NULL;

    int rootVal = postorder[*postIndex];
    (*postIndex)--;

    struct Node* root = createNode(rootVal);

    int inIndex = map[rootVal];

    // IMPORTANT: right first
    root->right = build(inorder, postorder, postIndex, inIndex + 1, inEnd, map);
    root->left = build(inorder, postorder, postIndex, inStart, inIndex - 1, map);

    return root;
}

void preorderPrint(struct Node* root) {
    if (!root) return;
    printf("%d ", root->val);
    preorderPrint(root->left);
    preorderPrint(root->right);
}

int main() {
    int n;
    scanf("%d", &n);

    int inorder[n], postorder[n];
    int map[1000];

    for (int i = 0; i < n; i++) {
        scanf("%d", &inorder[i]);
        map[inorder[i]] = i;
    }

    for (int i = 0; i < n; i++) {
        scanf("%d", &postorder[i]);
    }

    int postIndex = n - 1;

    struct Node* root = build(inorder, postorder, &postIndex, 0, n - 1, map);

    preorderPrint(root);

    return 0;
}

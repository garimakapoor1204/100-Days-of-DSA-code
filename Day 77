#include <stdio.h>
#include <stdlib.h>

// Definition for a Node
struct Node {
    int val;
    int numNeighbors;
    struct Node** neighbors;
};

// visited map (1–100 constraint)
struct Node* visited[101];

// Create node
struct Node* createNode(int val, int size) {
    struct Node* node = (struct Node*)malloc(sizeof(struct Node));
    node->val = val;
    node->numNeighbors = size;
    node->neighbors = (struct Node**)malloc(sizeof(struct Node*) * size);
    return node;
}

// Clone graph using DFS
struct Node* cloneGraph(struct Node* node) {
    if (node == NULL)
        return NULL;

    // already cloned
    if (visited[node->val] != NULL)
        return visited[node->val];

    // create clone
    struct Node* clone = createNode(node->val, node->numNeighbors);
    visited[node->val] = clone;

    // clone neighbors
    for (int i = 0; i < node->numNeighbors; i++) {
        clone->neighbors[i] = cloneGraph(node->neighbors[i]);
    }

    return clone;
}

#include <stdio.h>
#include <ctype.h>

char stack[100];
int top = -1;

void push(char x)
{
    stack[++top] = x;
}

char pop()
{
    return stack[top--];
}

int precedence(char op)
{
    if(op=='+' || op=='-')
        return 1;
    if(op=='*' || op=='/')
        return 2;
    return 0;
}

int main()
{
    char infix[100];
    int i=0;

    scanf("%s",infix);

    while(infix[i]!='\0')
    {
        if(isalnum(infix[i]))
            printf("%c",infix[i]);

        else
        {
            while(top!=-1 && precedence(stack[top])>=precedence(infix[i]))
                printf("%c",pop());

            push(infix[i]);
        }

        i++;
    }

    while(top!=-1)
        printf("%c",pop());

    return 0;
}

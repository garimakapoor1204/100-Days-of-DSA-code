// Q1(a) Queue using Array
#include <stdio.h>
#define SIZE 5

int q[SIZE];
int front = -1, rear = -1;

void enqueue(int x) {
    if (rear == SIZE - 1) return;
    if (front == -1) front = 0;
    q[++rear] = x;
}

void dequeue() {
    if (front == -1) return;
    if (front == rear)
        front = rear = -1;
    else
        front++;
}

void display() {
    if (front == -1) return;
    for (int i = front; i <= rear; i++)
        printf("%d ", q[i]);
}

int main() {
    enqueue(10);
    enqueue(20);
    enqueue(30);
    dequeue();
    display();
    return 0;
}
